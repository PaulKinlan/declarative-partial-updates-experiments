{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read server.ts",
    "start": "deno run --allow-net --allow-read server.ts",
    "check": "deno check server.ts examples/**/handler.ts",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "semiColons": true
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom"],
    "strict": true
  }
}
